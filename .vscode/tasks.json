{
  "version": "0.0.1",
  "tasks": [
      {
        "label": "Create .venv",
        "type": "shell",
        "command": "uv venv ${workspaceFolder}/.venv",
        "problemMatcher": []
      },
      {
        "label": "Install project",
        "type": "shell",
        "command": "uv pip install --python ${workspaceFolder}/.venv/bin/python -e ${workspaceFolder}",
        "problemMatcher": []
      },
      {
        "label": "Run CLI (MTUM)",
        "type": "shell",
        "command": "${workspaceFolder}/.venv/bin/python -m etfh_extractor https://www.ishares.com/us/products/251614/ishares-msci-usa-momentum-factor-etf",
        "group": "build",
        "problemMatcher": []
      },
      {
        "label": "Setup environment",
        "dependsOn": [
          "Create .venv",
          "Install project"
        ],
        "dependsOrder": "sequence",
        "problemMatcher": []
      }
  ]
}
